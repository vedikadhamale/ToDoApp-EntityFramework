@model IEnumerable<TODO_Entity.Models.TodoItem>

<div class="glass-card">
    <div class="page-header">
        <h2 class="mb-0">Todo List</h2>
        <a href="/TodoItems/Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Create New
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-borderless">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">
                            No tasks found. Start by creating a new one!
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.Title</td>
                        <td class="text-muted">@item.Description</td>
                        <td class="text-muted">
                            @if (item.DueDate.HasValue)
                            {
                                <i class="bi bi-calendar-event"></i> @item.DueDate.Value.ToString("MMM dd, yyyy")
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                        <td>
                            @if (item.IsCompleted)
                            {
                                <span class="badge bg-success-soft"><i class="bi bi-check-circle"></i> Completed</span>
                            }
                            else
                            {
                                <span class="badge bg-warning-soft"><i class="bi bi-clock"></i> Pending</span>
                            }
                        </td>
                        <td class="text-end actions-cell">
                            <form asp-action="ToggleComplete" asp-route-id="@item.Id" method="post" class="d-inline me-2" style="vertical-align: middle;">
                                <div class="form-check d-inline-block mb-0 p-0 m-0">
                                    <input class="form-check-input mt-0" type="checkbox" onchange="this.form.submit()" @(item.IsCompleted ? "checked" : "") title="Mark Complete/Incomplete" style="cursor: pointer; width: 1.5rem; height: 1.5rem; margin-right: 0.5rem;" />
                                </div>
                            </form>
                            <a href="/TodoItems/Edit/@item.Id" class="btn btn-success" title="Edit">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a href="/TodoItems/Delete/@item.Id" class="btn btn-danger" title="Delete">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>