@model TODO_Entity.Models.TodoItem

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="glass-card text-center">
            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 text-danger rounded-circle p-4 mb-3" style="width: 80px; height: 80px;">
                    <i class="bi bi-exclamation-triangle-fill fs-1"></i>
                </div>
                <h2>Delete Task?</h2>
                <p class="text-muted">Are you sure you want to delete this task? This action cannot be undone.</p>
            </div>

            <div class="card border mb-4 text-start shadow-sm">
                <div class="card-body">
                    <h5 class="card-title fw-bold">@Model.Title</h5>
                    <p class="card-text text-muted mb-2">@Model.Description</p>
                    
                    @if (Model.DueDate.HasValue)
                    {
                        <p class="card-text text-muted mb-3">
                            <i class="bi bi-calendar-event"></i> Due: @Model.DueDate.Value.ToString("MMM dd, yyyy")
                        </p>
                    }

                    <div>
                        @if (Model.IsCompleted)
                        {
                            <span class="badge bg-success-soft"><i class="bi bi-check-circle"></i> Completed</span>
                        }
                        else
                        {
                            <span class="badge bg-warning-soft"><i class="bi bi-clock"></i> Pending</span>
                        }
                    </div>
                </div>
            </div>

            <form asp-action="Delete" method="post" class="d-flex justify-content-center gap-3">
                <input type="hidden" asp-for="Id" />
                <a href="/TodoItems" class="btn btn-secondary px-4">
                    <i class="bi bi-x-lg"></i> Cancel
                </a>
                <button type="submit" class="btn btn-danger px-4">
                    <i class="bi bi-trash"></i> Yes, Delete
                </button>
            </form>
        </div>
    </div>
</div>